<Window x:Class="HeroArena.CreateCharacterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Créer un Personnage" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <TextBlock Text="CRÉER TON PERSONNAGE" FontSize="24" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Nom du personnage" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="CharacterNameBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,20"/>

            <TextBlock Text="Classe" Foreground="White" Margin="0,0,0,5"/>
            <ComboBox x:Name="ClassComboBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,20">
                <ComboBoxItem Content="Warrior"/>
                <ComboBoxItem Content="Mage"/>
                <ComboBoxItem Content="Assassin"/>
            </ComboBox>

            <Button Content="Créer le personnage" Height="50" Background="#4CAF50" Foreground="White" FontSize="16" Click="CreateButton_Click" Cursor="Hand" Margin="0,0,0,15"/>
            <Button Content="Annuler" Height="40" Background="#FF5722" Foreground="White" FontSize="14" Click="CancelButton_Click" Cursor="Hand"/>

            <TextBlock x:Name="MessageBox" Foreground="Red" Margin="0,15,0,0" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>