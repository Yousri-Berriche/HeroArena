<Window x:Class="HeroArena.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hero Arena - Login" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="HERO ARENA" FontSize="32" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="Username" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Password" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Height="40" Padding="10" FontSize="14" Margin="0,0,0,20"/>

            <Button Content="Se Connecter" Height="40" Background="#4CAF50" Foreground="White" FontSize="16" Click="LoginButton_Click" Cursor="Hand"/>

            <TextBlock x:Name="ErrorMessage" Foreground="Red" Margin="0,15,0,0" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>